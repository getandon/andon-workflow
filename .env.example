# Common
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
# Temporal TLS/mTLS (production): enable with TEMPORAL_TLS=true, add client certs for mTLS
# TEMPORAL_TLS=true
# TEMPORAL_TLS_CLIENT_CERT_PATH=/etc/andon/certs/tls.crt
# TEMPORAL_TLS_CLIENT_KEY_PATH=/etc/andon/certs/tls.key
# TEMPORAL_TLS_SERVER_ROOT_CA_PATH=/etc/andon/certs/ca.crt
# TEMPORAL_TLS_SERVER_NAME=temporal-frontend.example.com
# Temporal Cloud: TEMPORAL_TLS=true + TEMPORAL_API_KEY
# TEMPORAL_API_KEY=
#
# mTLS deployment:
#   Prod workers (within-cluster): internal URLs, Istio STRICT mTLS covers it
#     TEMPORAL_ADDRESS=temporal:7233 (no TEMPORAL_TLS)
#     ANDON_API_URL=http://api:3000
#   Dev/Test workers (cross-network via Istio gateway with MUTUAL TLS):
#     TEMPORAL_TLS=true
#     TEMPORAL_TLS_CLIENT_CERT_PATH=/etc/andon/certs/tls.crt
#     TEMPORAL_TLS_CLIENT_KEY_PATH=/etc/andon/certs/tls.key
#     TEMPORAL_TLS_SERVER_ROOT_CA_PATH=/etc/andon/certs/ca.crt
#     TEMPORAL_ADDRESS=andon-temporal.pix-xo.cloud:443
#     ANDON_API_URL=https://andon-api.pix-xo.cloud

# API
API_KEY=dev-key-change-me
PORT=3000

# Worker (set per environment)
TEMPORAL_TASK_QUEUE=production
WORKER_NAME=prod-worker-1
MONGODB_URI=mongodb://localhost:27017/production
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=andon-backups
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
MIGRATE_MONGO_PATH=./migrate-mongo-config.js
