# Copy this file to .env and fill in the values
# The .env file is git-ignored

# Task queue must be unique per worker fleet
TEMPORAL_TASK_QUEUE=local-task
WORKER_NAME=local-worker

# Andon API key — required
API_KEY=

# MongoDB connection to the production database — required
MONGODB_URI=

# AWS credentials for S3 backups — required
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional — override defaults if needed
# S3_REGION=eu-central-1
# S3_BUCKET=andon-backups
# WORKER_HEARTBEAT_INTERVAL_MS=30000
